# Poker44 miner deployment config.
# Copy to scripts/miner/miner.env and fill in your values, then run redeploy.sh / run_miner.sh.
# miner.env holds only public info (wallet NAME, hotkey NAME, public IP) — no private keys —
# but it is kept out of the published repo anyway.

export WALLET_NAME=my_cold
export HOTKEY=my_hotkey
export EXTERNAL_IP=YOUR.VDS.PUBLIC.IP     # public IP validators dial
export AXON_PORT=8091

# Public model repo for the transparent manifest (must contain the served code + model.pkl)
export POKER44_MODEL_REPO_URL=https://github.com/<you>/<your-repo>

# Empty = accept any validator-permit neuron (force_validator_permit). Or list hotkeys to restrict.
export ALLOWED_VALIDATOR_HOTKEYS=""

# bittensor 10.x: CLI arg parsing is opt-in — leave this on or the miner ignores every --flag.
export BT_NO_PARSE_CLI_ARGS=false

# Diagnostics: capture the unlabeled live validator queries (for miner_training.gap_diagnose).
# Fail-safe + gitignored. Uncomment to enable, then re-deploy and wait for validator queries.
# export POKER44_CAPTURE=1
